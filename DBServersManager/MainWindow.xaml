<Window x:Class="DBServersManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
    Title="DB Servers Manager" Height="670" Width="1160" MinWidth="960" MinHeight="540"
    WindowStartupLocation="CenterScreen"
    Background="#0C1A27"
    Icon="pack://application:,,,/Assets/DBServersManager.ico">

    <Window.Resources>

        <!-- Rounded button style -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.80"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.40"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark-theme CheckBox -->
        <Style x:Key="DarkCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#A8C8E8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ── Dark ComboBoxItem ── -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#C8DEF4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A4A8A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1565C0"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Dark ComboBox ── -->
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#C8DEF4"/>
            <Setter Property="Background" Value="#1A3653"/>
            <Setter Property="BorderBrush" Value="#2A5080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- Main border -->
                            <Border x:Name="MainBd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="28"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Selected text -->
                                    <ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      IsHitTestVisible="False"/>

                                    <!-- Drop arrow -->
                                    <ToggleButton Grid.Column="1"
                                                  Focusable="False"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  ClickMode="Press"
                                                  Background="Transparent"
                                                  BorderThickness="0">
                                        <Path Data="M 0 0 L 5 5 L 10 0 Z"
                                              Fill="#5AAEE0"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </ToggleButton>
                                </Grid>
                            </Border>

                            <!-- Popup -->
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=MainBd}"
                                   PopupAnimation="Fade"
                                   VerticalOffset="2">
                                <Border x:Name="DropBd"
                                    MinWidth="{Binding ActualWidth, ElementName=MainBd}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    Background="#112236"
                                    BorderBrush="#2A5080"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                    <ScrollViewer CanContentScroll="True"
                                                  Background="Transparent">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBd" Property="BorderBrush" Value="#5AAEE0"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="MainBd" Property="BorderBrush" Value="#5AAEE0"/>
                                <Setter TargetName="MainBd" Property="CornerRadius" Value="6,6,0,0"/>
                                <Setter TargetName="DropBd" Property="CornerRadius" Value="0,0,6,6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1A3653"/>
            <Setter Property="Foreground" Value="#C8DEF4"/>
            <Setter Property="BorderBrush" Value="#2A5080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="#C8DEF4"/>
        </Style>

        <!-- DataGrid row -->
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#0F2035"/>
            <Setter Property="Foreground" Value="#B8D0E8"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1A4A8A"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#122840"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid cell -->
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Column header -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#0A1E30"/>
            <Setter Property="Foreground" Value="#5AAEE0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="BorderBrush" Value="#1A3A5C"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
        </Style>

        <!-- Group header -->
        <Style TargetType="GroupItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupItem">
                        <StackPanel>
                            <Border Background="#0A1E30" Padding="12,6" Margin="0,2,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="4" CornerRadius="2" Margin="0,0,10,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#3FA7FF"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Name}" Value="MSSQL">
                                                        <Setter Property="Background" Value="#0078D4"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Name}" Value="MySQL">
                                                        <Setter Property="Background" Value="#E8820C"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Name}" Value="PostgreSQL">
                                                        <Setter Property="Background" Value="#336791"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#5AAEE0" FontSize="13"/>
                                    <TextBlock Text="{Binding ItemCount, StringFormat=' — {0} service(s)'}"
                                               Foreground="#3A6F9A" FontSize="12" Margin="4,0,0,0"/>
                                </StackPanel>
                            </Border>
                            <ItemsPresenter/>
                        </StackPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ════ Header ════ -->
        <Border Grid.Row="0" CornerRadius="12" Margin="0,0,0,10">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0C3461" Offset="0"/>
                    <GradientStop Color="#175FA6" Offset="0.6"/>
                    <GradientStop Color="#0E4A8A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <DockPanel LastChildFill="False" Margin="20,14">
                <StackPanel Orientation="Vertical" DockPanel.Dock="Left">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="36" Height="36" CornerRadius="8" Background="#1A6FC4"
                                Margin="0,0,12,0" VerticalAlignment="Center">
                            <TextBlock Text="DB" FontSize="13" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="Database Services Manager"
                                       FontSize="22" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Detect and control MSSQL · MySQL · PostgreSQL and related services"
                                       Foreground="#8FC8EE" FontSize="12" Margin="0,3,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                    <CheckBox x:Name="AutoStartCheckBox"
                              Style="{StaticResource DarkCheckBox}"
                              Content="Launch on Windows startup"
                              VerticalAlignment="Center"
                              Margin="0,0,18,0"
                              Checked="AutoStartCheckBox_OnChecked"
                              Unchecked="AutoStartCheckBox_OnUnchecked"/>
                    <Button Content="⟳  Refresh"
                            Style="{StaticResource ActionButton}"
                            Background="#1565C0"
                            Width="120" Height="36" Padding="0"
                            Click="RefreshButton_OnClick"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ════ Toolbar ════ -->
        <Border Grid.Row="1" CornerRadius="10" Background="#112030" Margin="0,0,0,10" Padding="14,11">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Search box with icon -->
                <Grid Grid.Column="0" Margin="0,0,10,0">
                    <TextBox x:Name="SearchTextBox"
                             Height="34" Padding="32,4,10,4"
                             VerticalContentAlignment="Center"
                             TextChanged="SearchTextBox_OnTextChanged"
                             ToolTip="Search by name, type or status"/>
                    <TextBlock Text="🔍" IsHitTestVisible="False"
                               VerticalAlignment="Center" Margin="9,0,0,0"
                               Foreground="#2A6090" FontSize="14"/>
                </Grid>

                <!-- Type filter -->
                <ComboBox x:Name="TypeFilterComboBox"
                          Grid.Column="1" Width="148" Height="34" Margin="0,0,10,0"
                          VerticalContentAlignment="Center"
                          SelectionChanged="TypeFilterComboBox_OnSelectionChanged"/>

                <!-- Sort -->
                <ComboBox x:Name="SortComboBox"
                          Grid.Column="2" Width="170" Height="34" Margin="0,0,10,0"
                          VerticalContentAlignment="Center"
                          SelectionChanged="SortComboBox_OnSelectionChanged">
                    <ComboBoxItem Content="Type (A-Z)" IsSelected="True"/>
                    <ComboBoxItem Content="Service Name (A-Z)"/>
                    <ComboBoxItem Content="Display Name (A-Z)"/>
                    <ComboBoxItem Content="Status"/>
                </ComboBox>

                <!-- Group toggle -->
                <CheckBox x:Name="GroupByTypeCheckBox"
                          Grid.Column="3"
                          Style="{StaticResource DarkCheckBox}"
                          Content="Group by type"
                          VerticalAlignment="Center"
                          Margin="0,0,16,0"
                          Checked="GroupByTypeCheckBox_OnChanged"
                          Unchecked="GroupByTypeCheckBox_OnChanged"/>

                <!-- Start all -->
                <Button x:Name="StartAllByTypeButton"
                        Grid.Column="4"
                        Style="{StaticResource ActionButton}"
                        Content="▶  Start all"
                        Background="#1B7A4E"
                        Width="120" Height="34" Padding="0"
                        Margin="0,0,8,0"
                        Click="StartAllByTypeButton_OnClick"/>

                <!-- Stop all -->
                <Button x:Name="StopAllByTypeButton"
                        Grid.Column="5"
                        Style="{StaticResource ActionButton}"
                        Content="■  Stop all"
                        Background="#9C2828"
                        Width="120" Height="34" Padding="0"
                        Margin="0,0,8,0"
                        Click="StopAllByTypeButton_OnClick"/>

                <!-- Tip -->
                <TextBlock Grid.Column="6" VerticalAlignment="Center"
                           TextWrapping="Wrap" FontSize="11"
                           Foreground="#3A6F9A"
                           Text="Run as Admin for full control. Minimize → tray."/>
            </Grid>
        </Border>

        <!-- ════ Services grid ════ -->
        <Border Grid.Row="2" CornerRadius="10" Background="#0C1E2E" Padding="0">
            <DataGrid x:Name="ServicesGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#162840"
                      RowHeaderWidth="0"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      AlternationCount="2"
                      Background="Transparent"
                      BorderThickness="0"
                      RowHeight="36">
                <DataGrid.Columns>

                    <!-- DB Type badge -->
                    <DataGridTemplateColumn Header="Type" Width="115" SortMemberPath="DatabaseType">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="6" Padding="8,3"
                                        HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1A3A5C"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DatabaseType}" Value="MSSQL">
                                                    <Setter Property="Background" Value="#0D3867"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding DatabaseType}" Value="MySQL">
                                                    <Setter Property="Background" Value="#5A3000"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding DatabaseType}" Value="PostgreSQL">
                                                    <Setter Property="Background" Value="#1A3652"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding DatabaseType}"/>
                                                <Setter Property="Foreground" Value="#5AAEE0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DatabaseType}" Value="MSSQL">
                                                        <Setter Property="Foreground" Value="#4DA6FF"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DatabaseType}" Value="MySQL">
                                                        <Setter Property="Foreground" Value="#F5A623"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DatabaseType}" Value="PostgreSQL">
                                                        <Setter Property="Foreground" Value="#63AFDE"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Service Name" Binding="{Binding ServiceName}" Width="2*"/>
                    <DataGridTextColumn Header="Display Name"  Binding="{Binding DisplayName}"  Width="3*"/>

                    <!-- Status badge -->
                    <DataGridTemplateColumn Header="Status" Width="140" SortMemberPath="Status">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="8" Padding="8,3"
                                        HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1A3A5C"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Running">
                                                    <Setter Property="Background" Value="#0D3D21"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Stopped">
                                                    <Setter Property="Background" Value="#3D0D0D"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                    <Setter Property="Background" Value="#3D2800"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="7" Height="7" Margin="0,0,6,0" VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#5AAEE0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Running">
                                                            <Setter Property="Fill" Value="#4ED48A"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Stopped">
                                                            <Setter Property="Fill" Value="#F47067"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                            <Setter Property="Fill" Value="#F5A623"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding Status}"/>
                                                    <Setter Property="Foreground" Value="#5AAEE0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Running">
                                                            <Setter Property="Foreground" Value="#4ED48A"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Stopped">
                                                            <Setter Property="Foreground" Value="#F47067"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                            <Setter Property="Foreground" Value="#F5A623"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Start Mode" Binding="{Binding StartType}" Width="120"/>

                    <!-- Action buttons -->
                    <DataGridTemplateColumn Header="Actions" Width="280">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="2,3">
                                    <Button Content="▶ Start"
                                            Background="#1B7A4E"
                                            Width="78" Height="27" Padding="0"
                                            Margin="0,0,6,0"
                                            Click="StartServiceButton_OnClick"
                                            CommandParameter="{Binding ServiceName}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource ActionButton}">
                                                <Setter Property="IsEnabled" Value="False" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Stopped">
                                                        <Setter Property="IsEnabled" Value="True" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                        <Setter Property="IsEnabled" Value="True" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="■ Stop"
                                            Background="#9C2828"
                                            Width="78" Height="27" Padding="0"
                                            Margin="0,0,6,0"
                                            Click="StopServiceButton_OnClick"
                                            CommandParameter="{Binding ServiceName}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource ActionButton}">
                                                <Setter Property="IsEnabled" Value="False" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Running">
                                                        <Setter Property="IsEnabled" Value="True" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                        <Setter Property="IsEnabled" Value="True" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="↺ Restart"
                                            Background="#7B4A00"
                                            Width="90" Height="27" Padding="0"
                                            Click="RestartServiceButton_OnClick"
                                            CommandParameter="{Binding ServiceName}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource ActionButton}">
                                                <Setter Property="IsEnabled" Value="False" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Running">
                                                        <Setter Property="IsEnabled" Value="True" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                        <Setter Property="IsEnabled" Value="True" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ════ Status bar ════ -->
        <Border Grid.Row="3" Margin="0,10,0,0" Background="#091828" CornerRadius="8" Padding="14,7">
            <DockPanel>
                <TextBlock Text="anzdev4life"
                           Foreground="#5AAEE0" FontSize="12"
                           DockPanel.Dock="Right"/>
                <Ellipse Width="8" Height="8" Fill="#3FA7FF"
                         DockPanel.Dock="Left" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusText" Text="Ready"
                           Foreground="#5AAEE0" FontSize="12"/>
            </DockPanel>
        </Border>

    </Grid>
</Window>
